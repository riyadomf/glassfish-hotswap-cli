# Application config — each key becomes a JNDI custom resource.
# Copy to env.properties and fill in your values:
#   cp env.properties.sample env.properties
#   chmod 600 env.properties
#
# Keys are registered under the JNDI_PREFIX defined in
# setup-glassfish-resources.sh (default: "app").
# Example: storage.path → app/storage.path
#
# Look up in your application with:
#   @Resource(lookup = "app/storage.path")
#   private String storagePath;

storage.path=/var/data/myapp
upload.max.size=10485760
